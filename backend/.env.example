PORT=4000
# Optional in production when the frontend is served by this backend on the same domain.
# If you deploy frontend separately, set the full frontend URL here.
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/socialgram
JWT_SECRET=change_this
# Optional: point this to a Render disk mount path if you add persistent storage.
UPLOAD_DIR=./uploads
